<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Post</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <nav>
    <a class="nav-logo" href="/posts">Stories That Shape Our World</a>
    <ul class="nav-links">
      <li><a href="/posts">Feed</a></li>
      <li><a href="/posts/new">New Post</a></li>
      <li class="dropdown">
        <a href="#">Account ▾</a>
        <div class="dropdown-menu">
          <a href="/login">Login</a>
          <a href="#">Profile</a>
          <a href="#">Settings</a>
          <a href="#">Sign Out</a>
        </div>
      </li>
    </ul>
  </nav>

  <div class="page">
    <div class="page-header">
      <h1>Edit <span>Post</span></h1>
      <p>Update your thought below.</p>
    </div>

    <div class="form-card">
      <h2>Editing @ <%= posts.username %></h2>
      <p class="subtitle">Change your content and save.</p>

      <form method="POST" action="/posts/<%= posts.id %>?_method=PATCH">
        <div class="form-group">
          <label for="content">Content</label>
          <textarea id="content" name="content" rows="4" required><%= posts.content %></textarea>
        </div>

        <div style="display:flex; gap:0.8rem; margin-top:0.5rem;">
          <button type="submit" class="btn btn-primary">Save Changes</button>
          <a href="/posts/<%= posts.id %>" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>

</body>
</html>
