<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <div class="login-wrapper">
    <div class="login-card">

      <div class="login-logo">
        <h1>Stories That Shape Our World</h1>
        <p>Welcome back — your words await.</p>
      </div>

      <form method="POST" action="/login">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" placeholder="Enter your username" required>
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:0.85rem;">
          Sign In →
        </button>
      </form>

      <div class="divider">or</div>

      <a href="/posts" class="btn btn-ghost" style="width:100%; justify-content:center; padding:0.85rem;">
        Continue as Guest
      </a>

      <div class="login-footer">
        Don't have an account? <a href="#">Sign up</a>
      </div>

    </div>
  </div>

</body>
</html>
