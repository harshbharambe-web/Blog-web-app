<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Post</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <nav>
    <a class="nav-logo" href="/posts">Stories That Shape Our World</a>
    <ul class="nav-links">
      <li><a href="/posts">Feed</a></li>
      <li><a href="/posts/new" class="active">New Post</a></li>
      <li class="dropdown">
        <a href="#">Account ▾</a>
        <div class="dropdown-menu">
          <a href="/login">Login</a>
          <a href="#">Profile</a>
          <a href="#">Settings</a>
          <a href="#">Sign Out</a>
        </div>
      </li>
    </ul>
  </nav>

  <div class="page">
    <div class="page-header">
      <h1>Share a <span>Thought</span></h1>
      <p>Your words matter — put them out there.</p>
    </div>

    <div class="form-card">
      <h2>New Post</h2>
      <p class="subtitle">Fill in your details below to publish.</p>

      <form method="POST" action="/posts">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" placeholder="e.g. harsh" required>
        </div>

        <div class="form-group">
          <label for="content">Your Thought</label>
          <textarea id="content" name="content" rows="4" placeholder="What's on your mind?" required></textarea>
        </div>

        <div style="display:flex; gap:0.8rem; margin-top:0.5rem;">
          <button type="submit" class="btn btn-primary">Publish →</button>
          <a href="/posts" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>

</body>
</html>
