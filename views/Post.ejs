<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Posts</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <nav>
    <a class="nav-logo" href="/posts">Stories That Shape Our World</a>
    <ul class="nav-links">
      <li><a href="/posts" class="active">Feed</a></li>
      <li><a href="/posts/new">New Post</a></li>
      <li class="dropdown">
        <a href="#">Account ▾</a>
        <div class="dropdown-menu">
          <a href="/login">Login</a>
          <a href="#">Profile</a>
          <a href="#">Settings</a>
          <a href="#">Sign Out</a>
        </div>
      </li>
    </ul>
  </nav>

  <div class="page">
    <div class="page-header">
      <h1>Today's <span>Stories</span></h1>
      <p>Thoughts shared by our community</p>
    </div>

    <% if(post.length === 0) { %>
      <div class="empty-state">
        <div class="icon">📝</div>
        <h3>No posts yet</h3>
        <p>Be the first to share something!</p>
        <br>
        <a href="/posts/new" class="btn btn-primary">Write a Post</a>
      </div>
    <% } else { %>
      <div class="cards-grid">
        <% for(let p of post) { %>
          <div class="card">
            <div class="card-username">@ <%= p.username %></div>
            <div class="card-content"><%= p.content %></div>
            <div class="card-footer">
              <a href="/posts/<%= p.id %>" class="btn btn-ghost" style="font-size:0.8rem; padding:0.45rem 1rem;">Read more →</a>
              <span class="badge badge-peach">Post</span>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <a href="/posts/new" class="fab" title="New Post">+</a>

</body>
</html>
